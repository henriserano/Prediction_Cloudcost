# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx
*.crt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — includes .env, .env.local, .env.production, etc. Template stays.
.env
.env.*
!.env.example
!.env.sample

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / OS
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo

# backup / temp
*.bak
*.orig
*.tmp
